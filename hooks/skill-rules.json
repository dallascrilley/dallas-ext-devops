{
  "version": "2.0",
  "skills": {
    "rclone": {
      "description": "S3/R2/B2 file transfer patterns using rclone",
      "priority": 5,
      "triggers": {
        "keywords": ["s3", "r2", "b2", "rclone", "file transfer", "sync"],
        "keywordPatterns": ["\\bs3\\b", "\\br2\\b", "\\bb2\\b", "\\brclone\\b"],
        "intentPatterns": [
          "(?:upload|download|sync|transfer).*(?:s3|r2|b2|bucket|storage)",
          "(?:rclone).*(?:sync|copy|move|config)"
        ]
      }
    },
    "github-ci-setup": {
